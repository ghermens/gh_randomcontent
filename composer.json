{
    "name": "amazing/gh-randomcontent",
    "description": "TYPO3 frontend plugin to show random content elements from selected page(s).",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "keywords": [
        "TYPO3",
        "extension",
        "random"
    ],
    "authors": [
        {
            "name": "Gregor Hermens",
            "email": "gregor.hermens@a-mazing.de",
            "homepage": "https://www.a-mazing.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ghermens/gh_randomcontent/issues",
        "source": "https://github.com/ghermens/gh_randomcontent",
        "docs": "https://docs.typo3.org/p/amazing/gh-randomcontent/main/en-us/"
    },
    "funding": [
        {
            "type": "paypal",
            "url": "https://paypal.me/gregorhermens"
        }
    ],
    "require": {
        "typo3/cms-core": "^12.4 || ^13.2 || ^14.3"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.44",
        "phpstan/phpstan": "^2.1.25",
        "phpunit/phpunit": "^11.2.5",
        "roave/security-advisories": "dev-latest",
        "typo3/coding-standards": "^0.8",
        "typo3/testing-framework": "^9.0.1"
    },
    "autoload": {
        "psr-4": {
            "Amazing\\GhRandomcontent\\": "Classes"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": ".Build/bin",
        "platform": {
            "php": "8.2.0"
        },
        "vendor-dir": ".Build/vendor"
    },
    "extra": {
        "typo3/cms": {
            "Package": {
                "providesPackages": []
            },
            "app-dir": ".Build",
            "extension-key": "gh_randomcontent",
            "version": "1.4.1",
            "web-dir": ".Build/public"
        }
    }
}
